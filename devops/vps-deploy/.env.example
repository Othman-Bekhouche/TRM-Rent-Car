# ========== PROJECT CONFIG ==========
PROJECT_NAME=TRM_Rent_Car
ORGANIZATION_NAME=TRM_Rent_Car
SITE_URL=http://localhost:5173
API_EXTERNAL_URL=http://localhost:8000
ADDITIONAL_REDIRECT_URLS=http://localhost:5173/*

# ========== DB CONFIG ==========
POSTGRES_PASSWORD=replace_with_secure_password

# ========== SECRETS (Generate with 'openssl rand -hex 32') ==========
# JWT Secret MUST be at least 32 characters long
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
ANON_KEY=replace_with_anon_key
SERVICE_ROLE_KEY=replace_with_service_role_key

# ========== SMTP CONFIG (For Auth Emails) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=trm.rentcar@gmail.com
SMTP_PASS=your_app_password
SMTP_SENDER_NAME=TRM Rent Car

# ========== STORAGE CONFIG ==========
S3_REGION=us-east-1
S3_BUCKET=supabase-bin

# ========== OPTIONAL ==========
OPENAI_API_KEY=sk-....
